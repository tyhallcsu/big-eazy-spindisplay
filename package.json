{
  "name": "svg-render-workflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "derive:svg": "node scripts/derive-simplified-svg.mjs --all",
    "build:logo": "node scripts/build-logo-renders.mjs",
    "build:concept": "node scripts/build-logo-renders.mjs",
    "build:examples": "node scripts/build-logo-renders.mjs --examples",
    "build:all-concepts": "node scripts/build-logo-renders.mjs --job-set big-eazy-concepts",
    "build:new-style-families": "node scripts/build-logo-renders.mjs --job-set big-eazy-new-style-families",
    "build:deployable-presets": "node scripts/build-logo-renders.mjs --job-set shared-deployable-presets",
    "build:spin": "node scripts/build-logo-renders.mjs --logo big-eazy --variant display --preset spindisplay-loop"
  },
  "dependencies": {
    "playwright": "^1.54.2",
    "three": "^0.179.1"
  }
}
